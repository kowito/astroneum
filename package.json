{
  "name": "astroneum",
  "version": "0.1.1",
  "description": "Astroneum - Professional financial charting library, ready out of the box.",
  "type": "module",
  "main": "./dist/astroneum.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/astroneum.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/astroneum.js",
      "default": "./dist/astroneum.js"
    },
    "./style.css": "./dist/astroneum.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./dist/astroneum.css"
  ],
  "files": [
    "LICENSE",
    "README.md",
    "dist/*.js",
    "dist/*.css",
    "dist/*.d.ts"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kowito/astroneum.git"
  },
  "bugs": {
    "url": "https://github.com/kowito/astroneum/issues"
  },
  "homepage": "https://github.com/kowito/astroneum#readme",
  "keywords": [
    "astroneum",
    "candlestick",
    "finance",
    "stock",
    "chart",
    "canvas"
  ],
  "author": "kowito",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{ recursive: true, force: true })\"",
    "build": "pnpm clean && tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "prepublishOnly": "pnpm verify"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "jsdom": "^29.0.2",
    "less": "^4.6.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^0.28.5"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "pnpm": {
    "overrides": {
      "vite": ">=6.4.2 <7",
      "esbuild": ">=0.25.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
