{
  "name": "astroneum",
  "version": "0.1.1",
  "description": "Astroneum - Professional financial charting library, ready out of the box.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/astroneum.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./style.css": "./dist/astroneum.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./dist/astroneum.css"
  ],
  "files": [
    "LICENSE",
    "README.md",
    "dist/*.js",
    "dist/*.css",
    "dist/*.d.ts"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kowito/astroneum.git"
  },
  "bugs": {
    "url": "https://github.com/kowito/astroneum/issues"
  },
  "homepage": "https://github.com/kowito/astroneum#readme",
  "keywords": [
    "astroneum",
    "candlestick",
    "finance",
    "stock",
    "chart",
    "canvas"
  ],
  "author": "kowito",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{ recursive: true, force: true })\"",
    "build:js": "tsup --config tsup.config.ts",
    "build:css": "lessc src/styles/index.less src/styles/.tmp-astroneum.css && esbuild src/styles/.tmp-astroneum.css --bundle --minify --loader:.eot=dataurl --loader:.ttf=dataurl --loader:.woff=dataurl --loader:.svg=dataurl --outfile=dist/astroneum.css && node -e \"const fs=require('node:fs');fs.rmSync('src/styles/.tmp-astroneum.css',{ force: true })\"",
    "build": "pnpm clean && pnpm build:js && pnpm build:css",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/__tests__/*.test.ts",
    "test:watch": "tsx --test --watch src/__tests__/*.test.ts",
    "lint": "eslint src",
    "verify": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "prepublishOnly": "pnpm verify"
  },
  "devDependencies": {
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "esbuild": "^0.25.11",
    "eslint": "^9.39.4",
    "less": "^4.6.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
